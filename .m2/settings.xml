<?xml version="1.0" encoding="UTF-8"?>
<settings xmlns="http://maven.apache.org/SETTINGS/1.2.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.2.0
          http://maven.apache.org/xsd/settings-1.2.0.xsd">
  <!-- 禁用全局 mirror，使用项目自己的仓库配置 -->
  <!-- 由于 Maven 会合并多个 settings.xml 的 mirror 配置，我们需要在构建脚本中临时替换全局 settings.xml -->
  <!-- 这里配置一个空的 mirrors 块，当项目的 settings.xml 替换全局 settings.xml 时，这个配置会生效 -->
  <mirrors>
  </mirrors>
  <profiles>
    <profile>
      <id>default-repositories</id>
      <repositories>
        <repository>
          <id>central</id>
          <name>Maven Central</name>
          <url>https://repo1.maven.org/maven2/</url>
          <releases>
            <enabled>true</enabled>
          </releases>
          <snapshots>
            <enabled>false</enabled>
          </snapshots>
        </repository>
        <repository>
          <id>metabase-maven-downloads</id>
          <name>Metabase Maven Downloads</name>
          <url>https://s3.amazonaws.com/metabase-maven-downloads</url>
          <releases>
            <enabled>true</enabled>
          </releases>
          <snapshots>
            <enabled>false</enabled>
          </snapshots>
        </repository>
        <repository>
          <id>redshift</id>
          <name>Redshift Maven Repository</name>
          <url>https://s3.amazonaws.com/redshift-maven-repository/release</url>
          <releases>
            <enabled>true</enabled>
          </releases>
          <snapshots>
            <enabled>false</enabled>
          </snapshots>
        </repository>
        <repository>
          <id>opensaml</id>
          <name>OpenSAML Repository</name>
          <url>https://build.shibboleth.net/nexus/content/repositories/releases/</url>
          <releases>
            <enabled>true</enabled>
            <updatePolicy>daily</updatePolicy>
            <checksumPolicy>warn</checksumPolicy>
          </releases>
          <snapshots>
            <enabled>false</enabled>
          </snapshots>
        </repository>
      </repositories>
      <pluginRepositories>
        <pluginRepository>
          <id>central</id>
          <name>Maven Central</name>
          <url>https://repo1.maven.org/maven2/</url>
          <releases>
            <enabled>true</enabled>
          </releases>
          <snapshots>
            <enabled>false</enabled>
          </snapshots>
        </pluginRepository>
      </pluginRepositories>
    </profile>
  </profiles>
  <activeProfiles>
    <activeProfile>default-repositories</activeProfile>
  </activeProfiles>
</settings>
